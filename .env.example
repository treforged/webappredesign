# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Supabase — get these from: https://supabase.com/dashboard/project/<id>/settings/api
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Cloudflare Turnstile — get site key from: https://dash.cloudflare.com/ → Turnstile
# Secret key goes in Supabase Edge Function secrets as TURNSTILE_SECRET_KEY (never here)
VITE_TURNSTILE_SITE_KEY=YOUR_TURNSTILE_SITE_KEY_HERE
